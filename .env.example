# [MODULE]   .env.example
# [TASK]     T1.1 — Project scaffold
#            T5.2 — Security hardening (app level)
# [SUBTASKS] T1.1.4 .env.example with every var from plan §3
#            T5.2.4 ALLOWED_FILE_HOSTS — optional file_url host allowlist (SSRF guard)
# [SUMMARY]  Template for the runtime environment file. Copy to `.env` (gitignored) and
#            fill in real values — never commit real secrets here. Every var below is
#            read by app/config.py:Settings (T1.1.2); names/defaults must stay in sync
#            with IMPLEMENTATION_PLAN.md §3 (Rule 7: env var names are a frozen contract
#            surface — renames require keeping the old name as an alias for a release).
# [PLAN]     IMPLEMENTATION_PLAN.md §3 → T1.1.4, T5.2.4
# [HISTORY]  2026-07-16  T1.1.4  initial template, all 9 vars from §3
#            2026-07-17  T5.2.4  add ALLOWED_FILE_HOSTS — additive, new optional var

# Static bearer token Laravel must send to us (Authorization: Bearer <this>)
OCR_API_KEY=long-random-hex

# Step 6 webhook target — Laravel endpoint we POST results to
LARAVEL_WEBHOOK_URL=https://erp.yourdomain.com/api/internal/ocr-webhook

# Bearer token we send to Laravel on the webhook call
LARAVEL_WEBHOOK_KEY=long-random-hex

# OpenAI auth
OPENAI_API_KEY=sk-your-openai-key-here

# LLM model for Step 5 structured extraction
OPENAI_MODEL=gpt-4o-mini

# Download guard (Step 2a) — abort mid-stream if the source file exceeds this size
MAX_FILE_SIZE_MB=25

# httpx timeout in seconds for the Step 2a file fetch
DOWNLOAD_TIMEOUT_S=30

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# true/false — dump intermediate pipeline images to a scratch dir with case_id prefix
DEBUG_SAVE_IMAGES=false

# Optional SSRF-guard allowlist: comma-separated file_url hosts, "*.domain.com" wildcard
# prefixes supported. Leave blank to allow any host that passes the private/loopback IP
# check (that check always applies, allowlisted or not).
ALLOWED_FILE_HOSTS=
