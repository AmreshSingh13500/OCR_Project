# ── Secrets — NEVER commit real credentials (only .env.example belongs in git) ──
.env
*.env.local
/etc/ocr-service/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ──
venv/
.venv/
env/

# ── Test & coverage artifacts ──
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── ML model caches / downloaded weights (multi-GB, always re-downloadable) ──
.cache/
.paddleocr/
paddle_models/
huggingface/
*.pdparams
*.pdmodel
*.onnx
*.pt
*.pth
*.safetensors

# ── Debug output (DEBUG_SAVE_IMAGES mode) & logs ──
debug_images/
tmp/
*.log

# ── IDE / OS noise ──
.vscode/
.idea/
Thumbs.db
.DS_Store
